# NVIDIA API (OpenAI-compatible endpoint)
OPENAI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_EMBEDDING_MODEL=nvidia/nv-embed-v1

# Storage directory (for persistent volume mounts in production)
# STORAGE_DIR=/app/storage
